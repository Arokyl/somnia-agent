# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# RPC endpoints
NEXT_PUBLIC_SOMNIA_RPC=https://api.infra.testnet.somnia.network/
NEXT_PUBLIC_SOMNIA_RPC_FALLBACK=https://dream-rpc.somnia.network
NEXT_PUBLIC_ETH_RPC=https://rpc.ankr.com/eth
NEXT_PUBLIC_ETH_RPC_FALLBACK=https://rpc.ankr.com/eth
NEXT_PUBLIC_BASE_RPC=https://rpc.ankr.com/base
NEXT_PUBLIC_BASE_RPC_FALLBACK=https://rpc.ankr.com/base
NEXT_PUBLIC_ARB_RPC=https://rpc.ankr.com/arbitrum
NEXT_PUBLIC_ARB_RPC_FALLBACK=https://rpc.ankr.com/arbitrum
SOMNIA_RPC=https://api.infra.testnet.somnia.network/
SOMNIA_RPC_FALLBACK=https://dream-rpc.somnia.network
SOMNIA_CHAIN_ID=50312
SOMNIA_EXPLORER_URL=https://shannon-explorer.somnia.network

# Contract deployment / runtime
# Decimal private key for Foundry vm.envUint. If you have a hex key, convert it to decimal first.
DEPLOYER_PRIVATE_KEY=0
# Optional hex private key alias for other tools. The deploy script uses DEPLOYER_PRIVATE_KEY.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
SOMNIA_EXPLORER_KEY=your_somnia_explorer_api_key
FEE_VAULT=0x0000000000000000000000000000000000000000
FEE_BPS=10
# Optional keeper address for external services; not used by the current deploy script.
KEEPER_ADDRESS=0xdE093Bf57d77E49b77010F239A252A7D53dbFd5E
EXECUTION_PROXY_ADDRESS=0x62ABDCFab87fbE9D66893C389C7D1B8AF6ffb9E5

# App runtime
FRONTEND_URL=http://localhost:3000
ETH_USD_PRICE=3000
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Contract addresses (fill after deploy)
NEXT_PUBLIC_EXECUTION_PROXY_SOMNIA=0x62ABDCFab87fbE9D66893C389C7D1B8AF6ffb9E5
NEXT_PUBLIC_EXECUTION_PROXY_ETH=0x

# Backend API
API_URL=http://localhost:3001
AGENT_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AGENT_URL=http://localhost:3002

# OpenAI-compatible LLM provider
OPENAI_API_KEY=your_openai_or_compatible_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 1inch
ONEINCH_API_KEY=your_key

# 0x Protocol
ZEROX_API_KEY=your_key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Redis (Upstash)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Server ports
API_PORT=3001
AGENT_PORT=3002
