# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id

# RPC endpoints
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC_FALLBACK=https://rpc.ankr.com/monad_testnet
NEXT_PUBLIC_ETH_RPC=https://rpc.ankr.com/eth
NEXT_PUBLIC_ETH_RPC_FALLBACK=https://rpc.ankr.com/eth
NEXT_PUBLIC_BASE_RPC=https://rpc.ankr.com/base
NEXT_PUBLIC_BASE_RPC_FALLBACK=https://rpc.ankr.com/base
NEXT_PUBLIC_ARB_RPC=https://rpc.ankr.com/arbitrum
NEXT_PUBLIC_ARB_RPC_FALLBACK=https://rpc.ankr.com/arbitrum
MONAD_RPC=https://testnet-rpc.monad.xyz
MONAD_RPC_FALLBACK=https://rpc.ankr.com/monad_testnet
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_URL=https://testnet.monadvision.com

# Contract deployment / runtime
# Decimal private key for Foundry vm.envUint. If you have a hex key, convert it to decimal first.
DEPLOYER_PRIVATE_KEY=0
# Optional hex private key alias for other tools. The deploy script uses DEPLOYER_PRIVATE_KEY.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE
MONAD_EXPLORER_KEY=your_monad_explorer_api_key
FEE_VAULT=0x0000000000000000000000000000000000000000
FEE_BPS=10
# Optional keeper address for external services; not used by the current deploy script.
KEEPER_ADDRESS=0xdE093Bf57d77E49b77010F239A252A7D53dbFd5E
EXECUTION_PROXY_ADDRESS=0xdBA2b47E8348b79422B736c4017336f44d2ff0a6

# App runtime
FRONTEND_URL=http://localhost:3000
ETH_USD_PRICE=3000
# Monad native token (MON) price in USD. MON is not on CoinGecko, so set it here.
# If unset or 0, MON balances are valued at $0 (API logs a warning).
MON_USD_PRICE=0
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Contract addresses (fill after deploy)
NEXT_PUBLIC_EXECUTION_PROXY_MONAD=0xdBA2b47E8348b79422B736c4017336f44d2ff0a6
NEXT_PUBLIC_EXECUTION_PROXY_ETH=0x

# Backend API
API_URL=http://localhost:3001
AGENT_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AGENT_URL=http://localhost:3002
# Local-only escape hatch. Leave unset/false in Vercel production so missing agent wiring fails loudly.
ALLOW_DEMO_AGENT=false

# OpenAI-compatible LLM provider
OPENAI_API_KEY=your_openai_or_compatible_api_key
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
OPENAI_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Subagent data APIs
MARKET_NEWS_API_URL=
MARKET_NEWS_API_KEY=
AIRDROP_FEED_URL=
AIRDROP_FEED_API_KEY=
WALLET_HISTORY_API_URL=https://deep-index.moralis.io/api/v2.2/wallets/{address}/history?chain={chainHex}
WALLET_HISTORY_API_KEY=
TRADE_IDEAS_API_URL=https://api.llama.fi/overview/dexs?excludeTotalDataChart=true&excludeTotalDataChartBreakdown=true
TRADE_IDEAS_API_KEY=
TRANSACTION_MONITOR_API_URL=https://deep-index.moralis.io/api/v2.2/wallets/{address}/history?chain={chainHex}
TRANSACTION_MONITOR_API_KEY=
USER_PROBLEM_FEED_URL=
USER_PROBLEM_FEED_API_KEY=
AGENT_AUDIT_FEED_URL=
AGENT_AUDIT_FEED_API_KEY=

# 1inch
ONEINCH_API_KEY=your_key

# 0x Protocol
ZEROX_API_KEY=your_key

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Redis (Upstash)
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# Server ports
API_PORT=3001
AGENT_PORT=3002
