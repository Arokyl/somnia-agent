{
  "name": "somnia-agent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @somnia-agent/web build",
    "build:api": "pnpm --filter @somnia-agent/shared build && pnpm --filter @somnia-agent/api build",
    "build:agent": "pnpm --filter @somnia-agent/shared build && pnpm --filter @somnia-agent/agent build",
    "build:backend": "pnpm build:api && pnpm build:agent",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "typecheck:web": "pnpm --filter @somnia-agent/web typecheck",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
