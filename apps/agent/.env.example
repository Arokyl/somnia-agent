# OpenAI-compatible LLM provider
OPENAI_API_KEY=your_groq_or_openai_compatible_api_key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Model pricing (USD per 1K tokens): overrides the built-in lookup table.
# Examples:
#   nvidia/nemotron-3-ultra-550b-a55b: {"input_per_1k": 0, "output_per_1k": 0}
#   moonshotai/kimi-k2.6 (NVIDIA NIM): {"input_per_1k": 0.0006, "output_per_1k": 0.0018}
#   gpt-4o-mini:                {"input_per_1k": 0.00015, "output_per_1k": 0.0006}
MODEL_PRICING={"input_per_1k": 0, "output_per_1k": 0}

# Agent service
AGENT_PORT=3002
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://somnia-agent.vercel.app
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
MONAD_RPC=https://testnet-rpc.monad.xyz
MONAD_RPC_FALLBACK=https://rpc.ankr.com/monad_testnet
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_URL=https://testnet.monadvision.com
EXECUTION_PROXY_ADDRESS=0xdBA2b47E8348b79422B736c4017336f44d2ff0a6
