# API service
API_PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://somnia-agent.vercel.app
DATABASE_URL=postgresql://user:password@host:5432/dbname

# RPC endpoints
SOMNIA_RPC=https://api.infra.testnet.somnia.network/
SOMNIA_RPC_FALLBACK=https://dream-rpc.somnia.network
SOMNIA_CHAIN_ID=50312
SOMNIA_EXPLORER_URL=https://shannon-explorer.somnia.network
NEXT_PUBLIC_SOMNIA_RPC=https://api.infra.testnet.somnia.network/
NEXT_PUBLIC_SOMNIA_RPC_FALLBACK=https://dream-rpc.somnia.network
ETH_USD_PRICE=3000
# Somnia native token (STT) is not listed on CoinGecko; set its USD price here.
# If unset or 0, STT balances are valued at $0 (API logs a warning).
STT_USD_PRICE=0

# Optional service integrations
REDIS_URL=redis://localhost:6379
ONEINCH_API_KEY=your_key
ZEROX_API_KEY=your_key
