# API service
API_PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,https://somnia-agent.vercel.app
DATABASE_URL=postgresql://user:password@host:5432/dbname

# RPC endpoints
MONAD_RPC=https://testnet-rpc.monad.xyz
MONAD_RPC_FALLBACK=https://rpc.ankr.com/monad_testnet
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_URL=https://testnet.monadvision.com
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC_FALLBACK=https://rpc.ankr.com/monad_testnet
ETH_USD_PRICE=3000
# ETH live price is fetched from DefiLlama/CoinGecko when available; this is the fallback.
# Monad native token (MON) is not listed on CoinGecko; set its USD price here.
# If unset or 0, MON balances are valued at $0 (API logs a warning).
MON_USD_PRICE=0

# Optional service integrations
REDIS_URL=redis://localhost:6379
ONEINCH_API_KEY=your_key
ZEROX_API_KEY=your_key
